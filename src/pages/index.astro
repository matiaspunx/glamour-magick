---
import Layout from "../layouts/Layout.astro"
import { Sparkles, Zap, FlaskConical, Target, PlayCircle, ChevronRight } from "lucide-react"

// La imagen ya está en public/hero.png
const heroImage = "/hero2.webp"
---

<Layout
  title="GLAMOUR MAGICK | El Arte de la Fascinación y Presencia"
  description="Masterclass online de 2 horas. Hackea cómo te perciben los demás usando alquimia interna, psicología de arquetipos y magia práctica."
>
  <!-- Header -->
  <header class="fixed top-6 left-1/2 -translate-x-1/2 z-100 w-[90%] max-w-4xl">
    <nav class="glass rounded-full px-6 py-3 flex items-center justify-between border-brand-plasma/20">
      <a href="/#" class="flex items-center gap-2">
        <div class="w-8 h-8 bg-brand-plasma rounded-lg flex items-center justify-center shadow-[0_0_15px_rgba(123,97,255,0.5)]">
          <Sparkles size={18} className="text-white" />
        </div>
        <span class="font-mono text-xs tracking-tighter uppercase font-bold text-brand-ghost">Glamour Magick</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-[10px] uppercase tracking-[0.2em] font-medium text-slate-400">
        <a href="#programa" class="hover:text-brand-cyan transition-colors">Programa</a>
        <a href="#nosotros" class="hover:text-brand-cyan transition-colors">Filosofía</a>
        <a href="#inscripcion" class="hover:text-brand-cyan transition-colors text-brand-cyan">Inscribirme</a>
      </div>
      <a href="#inscripcion" class="md:hidden text-brand-cyan text-[10px] font-bold uppercase">Reservar</a>
    </nav>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="relative min-h-dvh flex flex-col items-center justify-center pt-24 pb-12 px-6 overflow-hidden">
      <!-- Background Glows -->
      <div class="absolute top-1/4 -left-1/4 w-[60%] h-[60%] bg-brand-plasma/10 rounded-full blur-[120px] animate-pulse-glow"></div>
      <div class="absolute bottom-1/4 -right-1/4 w-[50%] h-[50%] bg-brand-cyan/10 rounded-full blur-[100px] animate-pulse-glow" style="animation-delay: 1s;">
      </div>

      <div class="container max-w-6xl relative z-10 grid lg:grid-cols-2 gap-12 items-center">
        <div class="text-center lg:text-left space-y-8" id="hero-content">
          <div class="hero-reveal reveal-hidden inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-plasma/10 border border-brand-plasma/30">
            <span class="w-2 h-2 rounded-full bg-brand-plasma animate-pulse"></span>
            <span class="text-[10px] font-mono uppercase tracking-[0.3em] text-brand-plasma font-bold">Masterclass Online (2 Horas)</span>
          </div>

          <div class="hero-reveal reveal-hidden">
            <h1 class="text-5xl md:text-8xl font-black uppercase tracking-tight leading-[0.9] text-brand-ghost">
              Glamour <span
                class="text-transparent bg-clip-text bg-linear-to-br from-brand-plasma via-brand-cyan to-brand-plasma bg-size-[200%_auto] animate-gradient"
                >Magick</span
              >
            </h1>
            <h2 class="text-3xl leading-none md:text-5xl opacity-80 italic font-display">El arte de la fascinación</h2>
          </div>

          <p class="hero-reveal reveal-hidden text-xl md:text-2xl text-slate-400 max-w-2xl mx-auto lg:mx-0 font-light leading-relaxed">
            Hackea cómo te perciben los demás usando <span class="text-brand-ghost font-medium">alquimia interna</span>, psicología de arquetipos y <span
              class="text-brand-ghost font-medium">magia práctica</span
            >.
          </p>

          <div class="hero-reveal reveal-hidden flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-6">
            <a
              href="#inscripcion"
              class="group relative px-8 py-4 bg-brand-plasma text-white font-black uppercase tracking-widest rounded-2xl transition-all hover:scale-105 active:scale-95 shadow-[0_0_30px_rgba(123,97,255,0.4)]"
            >
              <span class="relative text-pretty z-10 flex items-center gap-2">
                Quiero asegurar mi lugar
                <ChevronRight size={20} className="group-hover:translate-x-1 transition-transform" />
              </span>
              <div class="absolute inset-0 rounded-2xl bg-linear-to-r from-brand-plasma to-brand-cyan opacity-0 group-hover:opacity-100 transition-opacity">
              </div>
            </a>
            <div class="flex items-center gap-3 text-slate-500 font-mono text-xs uppercase tracking-wider">
              <PlayCircle size={18} />
              <span>Acceso inmediato a grabación</span>
            </div>
          </div>
        </div>

        <div class="relative group opacity-0 scale-95 transition-all duration-1000" id="hero-image-container">
          <div
            class="absolute -inset-4 bg-linear-to-r from-brand-plasma/20 to-brand-cyan/20 blur-2xl rounded-3xl opacity-50 group-hover:opacity-80 transition-opacity"
          >
          </div>
          <div class="relative rounded-3xl overflow-hidden border border-white/10 glass">
            <img
              src={heroImage}
              alt="Glamour Magick Hero Illustration"
              class="w-full aspect-square object-cover grayscale-[0.2] group-hover:grayscale-0 transition-all duration-700 hover:scale-105"
            />
            <div class="absolute inset-0 bg-linear-to-t from-brand-void/80 via-transparent to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6 p-4 glass rounded-2xl">
              <div class="flex items-center justify-between">
                <div class="space-y-1">
                  <p class="text-[10px] uppercase tracking-widest text-brand-plasma font-bold">Estado del Sistema</p>
                  <p class="text-xs font-mono text-brand-ghost">MAGNETISMO ACTIVADO: 95%</p>
                </div>
                <div class="h-2 w-24 bg-white/20 rounded-full overflow-hidden">
                  <div class="h-full bg-brand-plasma w-[95%] animate-pulse"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Intro Section -->
    <section class="py-24 px-6 relative" id="nosotros">
      <div class="container max-w-4xl mx-auto">
        <div class="space-y-12 text-center">
          <h2 class="reveal-hidden text-4xl md:text-6xl font-black uppercase tracking-tight text-brand-ghost section-title">
            No es suerte, <br /><span class="text-brand-cyan italic">es Glamour.</span>
          </h2>
          <div class="grid gap-8 text-lg md:text-xl text-slate-400 font-light leading-relaxed intro-text">
            <p>
              ¿Alguna vez te preguntaste por qué algunas personas consiguen los mejores trabajos, cautivan en sus citas y dominan cualquier habitación sin ser
              necesariamente "perfectos"? No es suerte ni belleza física, es <span
                class="text-brand-ghost font-medium underline decoration-brand-plasma underline-offset-8">Glamour</span
              >.
            </p>
            <p>
              En esta Masterclass intensiva y directa al grano, vamos a dejar de lado la solemnidad aburrida del ocultismo tradicional. Vas a aprender a
              fusionar la <span class="text-brand-cyan font-medium">brujería contemporánea</span>, la psicología de la persuasión y la alquimia antigua para
              convertirte en el protagonista de tu propia historia.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Programa / Modules -->
    <section class="py-24 px-6 bg-white/2" id="programa">
      <div class="container max-w-6xl mx-auto space-y-16">
        <div class="reveal-hidden text-center space-y-4">
          <p class="font-mono text-brand-plasma text-xs uppercase tracking-[0.4em]">Arquitectura del programa</p>
          <h2 class="text-5xl md:text-7xl font-black uppercase text-brand-ghost">Módulos</h2>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <!-- Module 1 -->
          <div class="reveal-hidden floating module-card group relative p-8 glass rounded-[2.5rem] hover:neon-border transition-all duration-500">
            <div
              class="mb-6 w-14 h-14 rounded-2xl bg-brand-plasma/10 flex items-center justify-center text-brand-plasma group-hover:scale-110 transition-transform"
            >
              <Target size={28} />
            </div>
            <h3 class="text-2xl font-bold mb-4 text-brand-ghost uppercase">Módulo 1: La Psicología de la Presencia</h3>
            <p class="text-slate-400 font-light leading-relaxed">
              El mito del Glamour. Identificación y uso estratégico de los <span class="text-brand-ghost">arquetipos de seducción</span> para entrevistas y citas.
              Domina la primera impresión.
            </p>
            <div class="mt-8 pt-6 border-t border-white/5 flex items-center justify-between text-[10px] font-mono uppercase tracking-widest text-slate-500">
              <span>01 / Psicología</span>
              <span class="text-brand-plasma">Active</span>
            </div>
          </div>

          <!-- Module 2 -->
          <div
            class="reveal-hidden floating module-card group relative p-8 glass rounded-[2.5rem] hover:neon-border-cyan transition-all duration-500"
            style="--float-duration: 3.8s; --float-delay: 0.5s;"
          >
            <div
              class="mb-6 w-14 h-14 rounded-2xl bg-brand-cyan/10 flex items-center justify-center text-brand-cyan group-hover:scale-110 transition-transform"
            >
              <Zap size={28} />
            </div>
            <h3 class="text-2xl font-bold mb-4 text-brand-ghost uppercase">Módulo 2: Alquimia interna y magnetismo</h3>
            <p class="text-slate-400 font-light leading-relaxed">
              La técnica secreta de <span class="text-brand-ghost">"La flor de oro"</span> para concentrar la energía vital, evitar la dispersión y proyectar una
              mirada magnética que no pasa desapercibida.
            </p>
            <div class="mt-8 pt-6 border-t border-white/5 flex items-center justify-between text-[10px] font-mono uppercase tracking-widest text-slate-500">
              <span>02 / Alquimia</span>
              <span class="text-brand-cyan">Active</span>
            </div>
          </div>

          <!-- Module 3 -->
          <div class="reveal-hidden floating module-card group relative p-8 glass rounded-[2.5rem] hover:neon-border transition-all duration-500">
            <div
              class="mb-6 w-14 h-14 rounded-2xl bg-brand-lime/10 flex items-center justify-center text-brand-lime group-hover:scale-110 transition-transform"
            >
              <FlaskConical size={28} />
            </div>
            <h3 class="text-2xl font-bold mb-4 text-brand-ghost uppercase">Módulo 3: Práctica de Consagración</h3>
            <p class="text-slate-400 font-light leading-relaxed">
              Creación y anclaje de un <span class="text-brand-ghost">"Perfume mágico"</span> usando magia del caos y psicología para hackear tu confianza antes de
              salir de casa.
            </p>
            <div class="mt-8 pt-6 border-t border-white/5 flex items-center justify-between text-[10px] font-mono uppercase tracking-widest text-slate-500">
              <span>03 / Taller</span>
              <span class="text-brand-lime">Live</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="py-32 px-6 relative overflow-hidden" id="inscripcion">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-brand-plasma/5 blur-[150px] pointer-events-none"></div>

      <div class="container max-w-4xl mx-auto">
        <div
          class="reveal-hidden pricing-card relative p-12 md:p-20 glass rounded-[3rem] border-brand-plasma/30 shadow-[0_0_50px_rgba(123,97,255,0.15)] text-center space-y-10 overflow-hidden"
        >
          <!-- Shine Effect -->
          <div class="absolute -top-1/2 -left-1/2 w-full h-full bg-linear-to-br from-brand-plasma/20 to-transparent rotate-45 pointer-events-none"></div>

          <div class="space-y-4 relative z-10">
            <h2 class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-brand-ghost">
              Valor del <span class="text-brand-plasma">taller</span>
            </h2>
            <p class="text-slate-400 uppercase font-mono text-[10px] tracking-[0.4em]">Únite a la nueva era del ocultismo práctico</p>
          </div>

          <div class="grid md:grid-cols-2 gap-12 items-center text-left relative z-10">
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <div class="mt-1 w-5 h-5 rounded-full bg-brand-plasma/20 flex items-center justify-center text-brand-plasma">
                  <ChevronRight size={14} />
                </div>
                <div class="space-y-1">
                  <p class="text-brand-ghost font-bold uppercase text-sm">Acceso en vivo</p>
                  <p class="text-slate-500 text-xs">Sesión interactiva de 2hs vía Telegram</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="mt-1 w-5 h-5 rounded-full bg-brand-plasma/20 flex items-center justify-center text-brand-plasma">
                  <ChevronRight size={14} />
                </div>
                <div class="space-y-1">
                  <p class="text-brand-ghost font-bold uppercase text-sm">Grabación disponible</p>
                  <p class="text-slate-500 text-xs">Acceso ilimitado por 30 días</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="mt-1 w-5 h-5 rounded-full bg-brand-plasma/20 flex items-center justify-center text-brand-plasma">
                  <ChevronRight size={14} />
                </div>
                <div class="space-y-1">
                  <p class="text-brand-ghost font-bold uppercase text-sm">Recurso Exclusivo</p>
                  <p class="text-slate-500 text-xs">PDF: La técnica del perfume mágico</p>
                </div>
              </li>
            </ul>

            <div class="bg-white/5 p-8 rounded-3xl border border-white/10 space-y-6 text-center md:text-right">
              <div class="space-y-1">
                <p class="text-slate-500 text-[10px] uppercase tracking-widest">Valor total</p>
                <div class="flex items-baseline justify-center md:justify-end gap-2">
                  <span class="text-5xl md:text-7xl font-black text-brand-ghost">$25</span>
                  <span class="text-xl text-brand-plasma font-mono">USD</span>
                </div>
                <p class="text-slate-500 text-xs">O $20.000 pesos argentinos</p>
              </div>

              <!-- Link de Pago aquí -->
              <a
                href="https://ig.me/m/__amti"
                class="block w-full py-4 bg-brand-ghost text-brand-void font-black uppercase rounded-2xl text-center hover:bg-brand-plasma hover:text-white transition-all shadow-xl hover:shadow-brand-plasma/40"
              >
                Unite ahora
              </a>
            </div>
          </div>
        </div>

        <div class="p-8 md:p-16 space-y-12 text-center">
          <p class="text-brand-ghost font-bold uppercase text-sm">
            Para cualquier consulta no dudes en escribirme por instagram a <a
              href="https://ig.me/m/__amti"
              class="text-brand-plasma hover:text-brand-cyan underline transition-colors">@__amti</a
            > o por email a <a href="mailto:matias.punx@gmail.com" class="text-brand-plasma hover:text-brand-cyan underline transition-colors"
              >matias.punx[a]gmail.com</a
            >
          </p>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="py-12 px-6 border-t border-white/5 bg-brand-void/50 backdrop-blur-sm">
    <div class="container max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center border border-white/10">
          <Sparkles size={20} className="text-brand-plasma" />
        </div>
        <p class="text-xs font-mono uppercase tracking-[0.2em] text-slate-500">© 2026 GLAMOUR MAGICK. Todos los derechos reservados.</p>
      </div>

      <div class="flex gap-8 text-[10px] uppercase tracking-[0.2em] font-medium text-slate-500">
        <a href="/terms" class="hover:text-brand-plasma transition-colors">Términos</a>
        <a href="/privacy" class="hover:text-brand-plasma transition-colors">Privacidad</a>
        <a href="mailto:matias.punx@gmail.com" class="hover:text-brand-plasma transition-colors">Contacto</a>
      </div>
    </div>
  </footer>
</Layout>

<script>
  import { gsap } from "gsap"
  import { ScrollTrigger } from "gsap/ScrollTrigger"

  gsap.registerPlugin(ScrollTrigger)

  // Entrance Animations (Héroe)
  // Usamos un timeline para el héroe con hero-reveal
  const heroTl = gsap.timeline()

  heroTl
    .to(".hero-reveal", {
      y: 0,
      opacity: 1,
      duration: 0.8,
      stagger: 0.1,
      ease: "power2.out"
    })
    .to(
      "#hero-image-container",
      {
        scale: 1,
        opacity: 1,
        duration: 1,
        ease: "power2.out"
      },
      "-=0.4"
    )

  // Reveal Animations para el resto de la página usando reveal-hidden
  const revealElements = document.querySelectorAll(".reveal-hidden:not(.hero-reveal)")

  revealElements.forEach((el) => {
    gsap.to(el, {
      scrollTrigger: {
        trigger: el,
        start: "top 85%",
        toggleActions: "play none none none"
      },
      y: 0,
      opacity: 1,
      duration: 0.8,
      ease: "power2.out"
    })
  })
</script>

<style>
  .animate-gradient {
    background-size: 200% 200%;
    animation: gradient 8s linear infinite;
  }

  @keyframes gradient {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }
</style>
